rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isShopMember(shopId) {
      return signedIn() && (
        (exists(/databases/$(database)/documents/shops/$(shopId)) &&
          get(/databases/$(database)/documents/shops/$(shopId)).data.ownerUid == request.auth.uid) ||
        exists(/databases/$(database)/documents/shops/$(shopId)/members/$(request.auth.uid))
      );
    }

    function isShopOwner(shopId) {
      return signedIn() && (
        (exists(/databases/$(database)/documents/shops/$(shopId)) &&
          get(/databases/$(database)/documents/shops/$(shopId)).data.ownerUid == request.auth.uid) ||
        (exists(/databases/$(database)/documents/shops/$(shopId)/members/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/shops/$(shopId)/members/$(request.auth.uid)).data.role == "owner")
      );
    }

    match /users/{userId} {
      allow read, create, update: if ownUserDoc(userId);
      allow delete: if false;
    }

    match /shops/{shopId} {
      allow read: if isShopMember(shopId);
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isShopOwner(shopId);
      allow delete: if false;

      match /members/{memberId} {
        allow read: if isShopMember(shopId);
        allow create, update: if isShopOwner(shopId);
        allow delete: if false;
      }

      match /bills/{billId} {
        allow read: if isShopMember(shopId)
          && resource.data.userId == request.auth.uid;
        allow create: if isShopMember(shopId)
          && request.resource.data.shopId == shopId
          && request.resource.data.userId == request.auth.uid;
        allow update: if isShopMember(shopId)
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isShopMember(shopId)
          && resource.data.userId == request.auth.uid;
      }

      match /customers/{customerId} {
        allow read: if isShopMember(shopId);
        allow create: if isShopMember(shopId);
        allow update: if isShopMember(shopId);
        allow delete: if isShopOwner(shopId);
      }

      match /categories/{categoryId} {
        allow read, create, update, delete: if isShopMember(shopId);
      }

      match /subcategories/{subcategoryId} {
        allow read, create, update, delete: if isShopMember(shopId);
      }

      match /items/{itemId} {
        allow read, create, update, delete: if isShopMember(shopId);
      }

      match /inventoryCategories/{categoryId} {
        allow read, create, update, delete: if isShopMember(shopId);

        match /subcategories/{subcategoryId} {
          allow read, create, update, delete: if isShopMember(shopId);

          match /items/{itemId} {
            allow read, create, update, delete: if isShopMember(shopId);
          }
        }
      }
    }
  }
}
